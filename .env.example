# Supabase Project URL (found in Supabase dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
# Supabase anon/public key (safe for client-side use; RLS enforces security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Supabase service role key (server-only; full database access — keep secret)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# DeepSeek API key (generated from DeepSeek platform dashboard)
DEEPSEEK_API_KEY=your_deepseek_api_key
# Upstash Redis REST URL (from Upstash Console > Redis Database > REST API)
UPSTASH_REDIS_REST_URL=your_upstash_url
# Upstash Redis REST Token (from Upstash Console > Redis Database > REST API)
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
